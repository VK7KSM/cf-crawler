# Cloudflare Worker 地址
CF_CRAWLER_ENDPOINT=https://your-worker-name.your-subdomain.workers.dev

# 你自己创建的访问密钥，值要和 `wrangler secret put CF_CRAWLER_TOKEN` 时输入的一样
CF_CRAWLER_TOKEN=replace-with-your-own-secret

# 请求超时（毫秒）
CF_CRAWLER_TIMEOUT_MS=20000

# 本地 SQLite 路径（可选）
CF_CRAWLER_DB_PATH=./data/db/crawler.sqlite

# 单域名冷却时间（毫秒）
CF_CRAWLER_HOST_COOLDOWN_MS=1200

# 请求失败后的最大重试次数
CF_CRAWLER_MAX_RETRIES=2

# 可选：限制只允许抓哪些域名，多个域名用逗号分隔
CF_CRAWLER_ALLOWED_HOSTS=

# 是否禁止访问私网 / 本地地址
CF_CRAWLER_BLOCK_PRIVATE_IP=true

# Agent-Reach 检查参数
AGENT_REACH_COMMAND=
AGENT_REACH_MIN_VERSION=
AGENT_REACH_AUTO_UPDATE=true
AGENT_REACH_TIMEOUT_MS=90000
